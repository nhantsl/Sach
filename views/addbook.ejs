<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Book</title>
    <link rel="stylesheet" href="css/output.css">
</head>
<body>
    <div class="max-w-md mx-auto bg-white shadow-md rounded-lg p-6 mt-10">
        <h1 class="text-2xl font-bold text-center text-gray-800 mb-6">
            Add a New Book
        </h1>

        <form action="/addbook" method="POST" id="addbook" class="flex flex-col gap-4">
            
            <div>
                <label for="nameProduct" class="block text-sm font-semibold text-gray-700 mb-1">
                    Title:
                </label>
                <input 
                    type="text" 
                    name="nameProduct" 
                    id="nameProduct" 
                    required
                    class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
            </div>

            <div>
                <label for="priceProduct" class="block text-sm font-semibold text-gray-700 mb-1">
                    Price:
                </label>
                <input 
                    type="number" 
                    name="priceProduct" 
                    id="priceProduct" 
                    required
                    class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
            </div>

            <input type="hidden" name="images" id="images">
            <input type="hidden" name="idCategory" id="idCategory">

            <button 
                type="submit"
                class="bg-green-500 text-white py-2 rounded hover:bg-green-600 transition"
            >
                Add Book
            </button>
        </form>

        <a 
            href="/" 
            class="block text-center text-green-600 mt-4 hover:underline"
        >
            Back to Book List
        </a>
    </div>
    <script>
    document.getElementById("addbook").addEventListener("submit", function() {
        const randomID = Math.floor(Math.random() * 5) + 1;
        document.getElementById("idCategory").value = randomID;
        document.getElementById("images").value = randomID + ".jpg";
    });
    </script>
</body>
</html>

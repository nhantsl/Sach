<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/output.css">
    <title>Giỏ hàng của bạn</title>
</head>

<body>
    <div class="mx-auto shadow-md rounded-lg p-6 mt-6">
        <h1 class="text-2xl font-bold text-center mb-4">Giỏ hàng của bạn</h1>
        <div class="text-center text-gray-700 mb-4">
            <span id="cart-count" class="font-bold text-lg">
                <%= cart.reduce((total, item) => total + item.quantity, 0) %>
            </span> 
                sản phẩm trong giỏ hàng
        </div>

        <% if (cart.length === 0) { %>
            <p class="text-center text-gray-500 mx-auto">
                Giỏ hàng của bạn hiện tại trống.
            </p>            
        <% } else { %>
            <ul class="cart-items space-y-3">
                <% cart.forEach(function(item) { %>
                    <li class="flex items-center max-w-5/6 mx-auto gap-4 p-3 rounded-lg shadow-sm hover:bg-gray-50 transition">

                        <!-- IMAGE -->
                        <div class="w-10">
                            <img 
                                src="images/<%= item.image %>" 
                                alt="<%= item.name %>"
                                class="object-cover rounded"
                            >
                        </div>

                        <!-- NAME -->
                        <span class="flex-1 font-medium text-gray-800">
                            <%= item.name %>
                        </span>

                        <!-- QUANTITY -->
                        <input 
                            type="number"
                            value="<%= item.quantity %>"
                            onchange="updateQuantity('<%= item.productId %>', this.value);"
                            class="w-16 border rounded px-2 py-1 text-center"
                        >

                        <!-- PRICE -->
                        <span class="text-gray-700 text-sm">
                            Giá: <%= item.price %>
                        </span>

                        <!-- TOTAL -->
                        <span class="text-green-600 font-semibold">
                            Tổng: <%= item.quantity * item.price %>
                        </span>

                        <!-- REMOVE -->
                        <button 
                            onclick="removeProduct('<%= item.productId %>')"
                            class="text-red-500 hover:text-red-700 font-bold"
                        >
                            ✕
                        </button>

                    </li>
                <% }) %>

            </ul>

        <% } %>

        <!-- BACK BUTTON -->
        <div class="text-center mt-6">
            <a 
                href="/"
                class="inline-block bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition"
            >
                Quay lại trang chủ
            </a>
        </div>

    </div>

    <script>
        function updateCartInfo(cart) {
            const cartCount = cart.reduce((total, item) => total + item.quantity, 0);
            document.getElementById('cart-count').textContent = cartCount;
        }
        
        function updateQuantity(productId, quantity) {
            quantity = parseInt(quantity, 10);

            fetch('/cart/update', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: productId, quantity: quantity })
            })
            .then(response => response.json())

            .then(data => {
                renderCartItems(data.cart);
                updateCartInfo(data.cart);
            })
            .catch(error => {
                console.error("Lỗi khi cập nhật giỏ hàng:", error);
            });
        }

        function removeProduct(productId) {           
            fetch('/cart/remove', {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ productId: productId })
            })
            .then(response => response.json())
            .then(data => {
                renderCartItems(data.cart);
                updateCartInfo(data.cart);
            })
            .catch(error => {
                console.error('Có lỗi khi xóa sản phẩm:', error);
            });
        }

        function renderCartItems(cart) {
            const cartItemsContainer = document.querySelector('.cart-items');
            cartItemsContainer.innerHTML = ''; 

            if (cart.length === 0) {
                cartItemsContainer.innerHTML = 
                '<p class="text-center text-gray-500 mx-auto">Giỏ hàng của bạn hiện tại trống.</p> <a class="cart-footer" href="/">Quay lại trang chủ</a>';
                document.querySelector('.cart-footer').style.display = 'none';
            } else {
                cart.forEach(item => {
                    cartItemsContainer.innerHTML += `
                        <li class="flex items-center max-w-5/6 mx-auto gap-4 p-3 rounded-lg shadow-sm hover:bg-gray-50 transition">

                        <!-- IMAGE -->
                        <div class="w-10">
                            <img 
                                src="images/${item.image}" 
                                alt="${item.name}"
                                class="object-cover rounded"
                            >
                        </div>

                        <!-- NAME -->
                        <span class="flex-1 font-medium text-gray-800">
                            ${item.name}
                        </span>

                        <!-- QUANTITY -->
                        <input 
                            type="number"
                            value="${item.quantity}"
                            onchange="updateQuantity('${item.productId}', this.value)"
                            class="w-16 border rounded px-2 py-1 text-center"
                        >

                        <!-- PRICE -->
                        <span class="text-gray-700 text-sm">
                            Giá: ${item.price}
                        </span>

                        <!-- TOTAL -->
                        <span class="text-green-600 font-semibold">
                            Tổng: ${item.quantity * item.price}
                        </span>

                        <!-- REMOVE -->
                        <button 
                            onclick="removeProduct('${item.productId}')"
                            class="text-red-500 hover:text-red-700 font-bold"
                        >
                            ✕
                        </button>

                    </li>
                    `;
                });
                document.querySelector('.cart-footer').style.display = 'block';
            }
        }

        fetch('/cart/api')
            .then(response => {
                if (!response.ok) {
                    throw new Error('API trả về lỗi.');
                }
                return response.json();
            })
            .then(data => {
                console.log('Giỏ hàng:', data.cart);
                updateCartInfo(data.cart);
                renderCartItems(data.cart);
            })
            .catch(error => {
                console.error('Lỗi khi tải giỏ hàng:', error);
            });
    </script>

</body>

</html>
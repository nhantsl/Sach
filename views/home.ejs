<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poly Book Store</title>
    <link rel="stylesheet" href="/css/output.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
</head>

<body class="font-sans bg-gray-100 min-h-screen m-0 p-0">
    <header class="bg-gray-800 text-white px-5 py-3">
        <nav class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center justify-between w-full sm:w-auto">
                <a href="/" class="text-xl font-bold hover:text-gray-300">
                    Poly Book Store
                </a>
            </div>         
            
            <div class="w-full sm:w-auto">
                <form action="/" method="get" class="flex gap-2">
                    <input 
                        type="text" 
                        name="search" 
                        placeholder="Tìm kiếm sản phẩm..." 
                        required
                        class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400"
                    >

                    <button
                        type="submit" 
                        class=" px-4 py-2 rounded-md hover:bg-gray-700 transition"
                    >
                        <i class="fas fa-search"></i>
                    </button>

                </form>
            </div>


            <ul class="flex">
                <li class="relative">
                    <button onclick="toggleDropdown()" class="px-3 py-2 text-white text-xl">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <ul id="dropdownMenu" class="hidden absolute bg-gray-800 rounded mt-2 w-48">
                        
                        <% catalogs.forEach(function(cate) { %>
                            <li>
                                <a href="/?idCatalog=<%= cate.idCatalog %>"
                                    class="block px-4 py-2 text-white hover:bg-gray-700 <%= cate.active ? 'active' : '' %>">
                                    <%= cate.nameCatalog %>
                                </a>
                            </li>
                        <% }) %>

                    </ul>
                </li>
            </ul>

            <div class="flex items-center gap-4">

                <% if (!user || user.role !== 1) { %>
                    <a href="/cart" id="cart-link" class="relative text-white text-xl hover:text-gray-300">
                        <i class="fas fa-shopping-cart"></i>

                        <!-- cart count -->
                        <span id="cart-count"
                            class="absolute -top-2 -right-2 bg-red-500 text-white text-xs px-1.5 rounded-full">
                            <%= cartCount %>
                        </span>
                    </a>
                <% } %>

                <!-- ADMIN -->
                <% if (user && user.role === 1) { %>
                    <div class="flex items-center gap-3 text-white text-xl">
                        <a href="/addbook" class="hover:text-green-400">
                            <p class="font-bold">Thêm sách</p>
                        </a>

                        <a href="/removebook" class="hover:text-red-400">
                            <p class="font-bold">Xóa sách</p>
                        </a>
                    </div>
                <% } %>

                <!-- AUTH -->
                <div class="text-white text-xl">
                    <% if (user) { %>
                        <a href="/cart/logout" class="hover:text-red-400">
                            <i class="fa-solid fa-right-from-bracket"></i>
                        </a>
                    <% } else { %>
                        <a href="/cart/login" class="hover:text-blue-400">
                            <i class="fa-solid fa-user"></i>
                        </a>
                    <% } %>
                </div>

            </div>

        </nav>
    </header>
    <main align="center">
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-5 justify-items-center p-3">
            <% if (!products || products.length === 0) { %>
                <p class="col-span-full text-center text-gray-600">
                    <%= message || 'Không có sản phẩm nào.' %>
                </p>
            <% } else { %>
                <% products.forEach(function(product) { %>
                    <article class="w-full shadow-sm rounded">
                        <!-- TITLE -->
                        <header class="p-3">
                            <h1 class="text-lg font-semibold">
                                <%= product.nameProduct %>
                            </h1>
                        </header>

                        <!-- IMAGE -->
                        <div>
                            <img 
                                class="object-cover w-3/4 sm:h-40 md:h-100 lg:h-full rounded-lg mx-auto"
                                src="images/<%= product.images %>" 
                                alt="Product Image" 
                            >
                        </div>

                        <!-- CONTENT -->
                        <div class="p-3 flex-1">
                            <h2 class="text-green-600 font-bold text-lg">
                                <%= product.priceProduct %> đ
                            </h2>
                        </div>

                        <!-- ACTION -->
                        <div class="p-3">
                            <button 
                                class="w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition text-sm sm:text-base"
                                onclick="add('<%= product.idProduct %>', 
                                            '<%= product.nameProduct %>', 
                                            '<%= product.priceProduct %>', 
                                            '<%= product.images %>', 1)"
                            >
                                Add to Cart
                            </button>
                        </div>

                    </article>
                <% }); %>

            <% } %>

        </div>
        
        <nav class="flex justify-center items-center gap-2 mt-6 mb-2">

            <% if (products && products.length > 0) { %>
                <% for (let i = 1; i <= totalPages; i++) { %>

                    <a href="/?page=<%= i %>&limit=8"
                    class="px-3 py-1 border rounded-md text-sm transition
                            <%= currentPage === i 
                                ? 'bg-blue-500 border-blue-500' 
                                : 'bg-white hover:bg-gray-100' %>">
                        <%= i %>
                    </a>

                <% } %>
            <% } %>

        </nav>
    </main>

    <div id="toast" class="fixed top-5 right-5 hidden">
        <div id="toast-content" class="bg-green-500 text-white px-4 py-2 rounded shadow-lg transition">
        </div>
    </div>
    
    <script>
        function toggleDropdown() {
            const menu = document.getElementById("dropdownMenu");
            menu.classList.toggle("hidden");
        }
        
        function showToast(message, type = "success") {
            const toast = document.getElementById('toast');
            const content = document.getElementById('toast-content');

            content.textContent = message;

            // đổi màu theo type
            content.className = "text-white px-4 py-2 rounded shadow-lg transition " + 
                (type === "error" ? "bg-red-500" : "bg-green-500");

            toast.classList.remove('hidden');

            setTimeout(() => {
                toast.classList.add('hidden');
            }, 2000);
        }

        function add(productId,nameProduct, priceProduct, images, quantity) {
            fetch('/cart/add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    productId: productId,
                    nameProduct: nameProduct,   
                    priceProduct: priceProduct, 
                    image: images,              
                    quantity: quantity
                })
            })
                .then(response => response.json())
                .then(data => {
                    showToast(data.message);
                    updateCartInfo(data.cart); 
                })
                .catch(error => {
                    console.error('Lỗi khi thêm vào giỏ hàng:', error);
                });
        }

        function updateCartInfo(cart) {
            const cartCount = cart.reduce((total, item) => total + item.quantity, 0);
            document.getElementById('cart-count').textContent = cartCount;
        }

        document.getElementById('cart-link').addEventListener('click', function(e) {
        e.preventDefault();

            fetch('/cart')
                .then(response => {
                    if (response.status === 401) {
                        return response.json();
                    } else {
                        window.location.href = '/cart';
                        return null;
                    }
                })
                .then(data => {
                    if (data.message) {
                        showToast(data.message);
                    }
                })
                .catch(error => {
                    console.error('Có lỗi xảy ra:', error);
                });
        });
    </script>
</body>

</html>